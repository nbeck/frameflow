# FrameFlow environment configuration
# Copy this file to .env and adjust values for your environment.

# Runtime environment label (development | production)
FRAMEFLOW_ENVIRONMENT=development

# Absolute or relative path to the photo library directory.
# This directory must exist before FrameFlow starts.
FRAMEFLOW_PHOTO_LIBRARY=photos

# Path where FrameFlow will create the SQLite database file.
# The parent directory is created automatically if it does not exist.
FRAMEFLOW_DATABASE_PATH=data/frameflow.db

# Log level passed to the Python logging system (DEBUG | INFO | WARNING | ERROR).
FRAMEFLOW_LOG_LEVEL=INFO

# Enable the background scheduled sync loop.
# When false, sync must be triggered manually via POST /sync.
FRAMEFLOW_SYNC_ENABLED=false

# How often the background sync loop runs, in seconds. Must be greater than 0.
# The loop waits this full interval before its first run.
FRAMEFLOW_SYNC_INTERVAL_SECONDS=300

# Host and port used by the preferred startup command (uv run frameflow / python -m frameflow).
# Set to 0.0.0.0 to accept connections on all interfaces.
# Display clients (e.g. DAKboard) on the local network require 0.0.0.0 or the server's LAN IP.
# Note: these are ignored when using `uv run uvicorn frameflow.api.app:app` directly.
FRAMEFLOW_HOST=127.0.0.1
FRAMEFLOW_PORT=8000
